{
  "name": "deal-pipeline",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "core:test": "cargo test --manifest-path deal-core/Cargo.toml",
    "core:wasm": "wasm-pack build deal-core --target web --out-dir ../src/wasm/deal-core && node -e \"require('fs').rmSync('src/wasm/deal-core/.gitignore', { force: true })\"",
    "test:fixtures": "node scripts/run-regression-fixtures.js",
    "test": "npm run core:test && npm run test:fixtures"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "canvas-confetti": "^1.6.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
